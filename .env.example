APP_NAME="PDF Knowledge Assistant"
APP_ENV=development
LOG_LEVEL=INFO

# Storage paths are relative to the project root by default.
UPLOAD_DIR=storage/uploads
INDEX_DIR=storage/index

# Embedding model. all-MiniLM-L6-v2 is small and works well for demos.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=5

# Choose one: gemini, openai, or mock.
LLM_PROVIDER=mock

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
