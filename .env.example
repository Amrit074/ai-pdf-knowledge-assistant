APP_NAME="PDF Knowledge Assistant"
APP_ENV=development
LOG_LEVEL=INFO

# Storage paths are relative to the project root by default.
UPLOAD_DIR=storage/uploads
INDEX_DIR=storage/index

# Use gemini for cloud deployment on small instances, or hash for offline demos.
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSION=768
EMBEDDING_BATCH_SIZE=16
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=5

# Choose one: gemini, openai, or mock.
LLM_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
